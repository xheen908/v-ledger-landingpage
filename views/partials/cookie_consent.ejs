<!-- Simple Cookie Consent Banner -->
<div id="cookie-barrier" class="fixed inset-0 z-[10000] bg-black/40 backdrop-blur-[2px] opacity-0 pointer-events-none transition-opacity duration-500 flex items-end">
    <!-- Clean, full-width bottom bar -->
    <div class="w-full bg-[#111] border-t border-white/10 px-4 md:px-8 py-4 shadow-[0_-10px_40px_rgba(0,0,0,0.5)] relative">
        <div class="w-full max-w-7xl mx-auto flex flex-col lg:flex-row items-center justify-between gap-4 md:gap-6">
            
            <div class="flex items-start md:items-center gap-4 text-white/80">
                <div class="p-2 bg-white/5 rounded-full shrink-0">
                    <svg class="w-5 h-5 text-[#a88c5a]" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 2a10 10 0 1010 10 4 4 0 01-5-5 4 4 0 01-5-5z"></path>
                        <circle cx="8.5" cy="10.5" r="1" fill="currentColor" stroke="none"></circle>
                        <circle cx="14.5" cy="13.5" r="1" fill="currentColor" stroke="none"></circle>
                        <circle cx="10.5" cy="15.5" r="1" fill="currentColor" stroke="none"></circle>
                    </svg>
                </div>
                <div class="text-sm">
                    <span class="font-bold text-white mr-2"><%= t.cookie.title %></span>
                    <span class="text-white/60"><%= t.cookie.msg %></span>
                </div>
            </div>
            
            <!-- Actions -->
            <div class="flex items-center gap-3 shrink-0 w-full lg:w-auto mt-2 lg:mt-0">
                <button id="cookie-settings" class="text-xs font-semibold text-white/40 hover:text-white transition-colors px-2 py-2 underline underline-offset-4 mr-auto lg:mr-2">
                    <%= t.cookie.settings %>
                </button>
                <button id="cookie-reject" class="px-5 py-2.5 rounded-lg border border-white/20 bg-transparent hover:bg-white/5 text-xs font-bold text-white transition-all whitespace-nowrap">
                    <%= t.cookie.reject %>
                </button>
                <button id="cookie-accept" class="px-6 py-2.5 rounded-lg bg-[#a88c5a] hover:bg-[#bca06f] text-black text-xs font-bold transition-all whitespace-nowrap shadow-[0_0_15px_rgba(168,140,90,0.3)]">
                    <%= t.cookie.accept %>
                </button>
            </div>
            
        </div>
    </div>
</div>
