<!DOCTYPE html>
<html lang="<%= t.lang %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/png" href="/assets/coin-icon.png">
    <title><%= t.metaTitle %></title>
    <meta name="description" content="<%= t.metaDesc %>">
    
    <!-- SEO: Canonical and Hreflang Clusters (Global AI Indexing) -->
    <link rel="canonical" href="https://V-Ledger.com/<%= t.lang %>/">
    <!-- Hreflang Clusters (Global AI Indexing) -->
    <link rel="alternate" hreflang="de-de" href="https://V-Ledger.com/de-de/">
    <link rel="alternate" hreflang="en-us" href="https://V-Ledger.com/en-us/">
    <link rel="alternate" hreflang="es-es" href="https://V-Ledger.com/es-es/">
    <link rel="alternate" hreflang="vi-vn" href="https://V-Ledger.com/vi-vn/">
    <link rel="alternate" hreflang="th-th" href="https://V-Ledger.com/th-th/">
    <link rel="alternate" hreflang="ja-jp" href="https://V-Ledger.com/ja-jp/">
    <link rel="alternate" hreflang="ko-kr" href="https://V-Ledger.com/ko-kr/">
    <link rel="alternate" hreflang="hi-in" href="https://V-Ledger.com/hi-in/">
    <link rel="alternate" hreflang="bn-bd" href="https://V-Ledger.com/bn-bd/">
    <link rel="alternate" hreflang="zh-cn" href="https://V-Ledger.com/zh-cn/">
    <link rel="alternate" hreflang="zh-tw" href="https://V-Ledger.com/zh-tw/">
    <link rel="alternate" hreflang="x-default" href="https://V-Ledger.com/en-us/">

    <!-- Social Preview: Open Graph (LinkedIn/Meta) -->
    <meta property="og:title" content="<%= t.metaTitle %>">
    <meta property="og:description" content="<%= t.metaDesc %>">
    <meta property="og:image" content="https://V-Ledger.com/assets/hero-elite.png">
    <meta property="og:url" content="https://V-Ledger.com/<%= t.lang %>/">
    <meta property="og:type" content="website">

    <!-- Social Preview: Twitter/X -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= t.metaTitle %>">
    <meta name="twitter:description" content="<%= t.metaDesc %>">
    <meta name="twitter:image" content="https://V-Ledger.com/assets/hero-elite.png">

    <!-- JSON-LD Structured Data (Machine Readability & AI Agents) -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Organization",
          "@id": "https://V-Ledger.com/#organization",
          "name": "V-LEDGER",
          "url": "https://V-Ledger.com",
          "logo": "https://V-Ledger.com/assets/logo.png",
          "address": {
            "@type": "PostalAddress",
            "streetAddress": "Albertstr. 7",
            "postalCode": "47059",
            "addressLocality": "Duisburg",
            "addressCountry": "DE"
          }
        },
        {
          "@type": "LocalBusiness",
          "name": "V-LEDGER",
          "image": "https://V-Ledger.com/assets/hero-elite.png",
          "address": {
            "@type": "PostalAddress",
            "streetAddress": "Albertstr. 7",
            "postalCode": "47059",
            "addressLocality": "Duisburg",
            "addressRegion": "NRW",
            "addressCountry": "DE"
          },
          "description": "Gateway for European ESPR 2027 Compliance at Port of Duisburg.",
          "url": "https://V-Ledger.com"
        },
        {
          "@type": "TechArticle",
          "headline": "V-Ledger: Die Zukunft der ESPR-Compliance (DPP)",
          "description": "<%= t.metaDesc %>",
          "author": { "@id": "https://V-Ledger.com/#organization" },
          "keywords": ["Digital Product Passport", "ESPR 2027", "Battery Passport", "Textiles Compliance", "Duisburg Gateway", "Base L2 Blockchain"]
        },
        {
          "@type": "FAQPage",
          "mainEntity": [
            <% t.faqs.forEach((faq, index) => { %>
            {
              "@type": "Question",
              "name": "<%= faq.q %>",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "<%= faq.a %>"
              }
            }<%= index < t.faqs.length - 1 ? ',' : '' %>
            <% }); %>
          ]
        }
      ]
    }
    </script>

    <!-- External Resources -->
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/lipis/flag-icons@7.2.3/css/flag-icons.min.css" />
    <link rel="stylesheet" href="/css/style.css?v=13.3-SSR">

    <!-- SES-Proof Scripts (Programmatic Only) -->
    <script src="/js/main.js?v=13.3-SSR" defer></script>
</head>
<body class="selection:bg-white/10">
    <div class="mesh-bg"></div>

    <%- include('partials/header', { t }) %>

    <main class="max-w-7xl mx-auto px-6 py-20 md:py-40">
        <!-- Hero Section: Build 9.0 Immersive -->
        <div class="grid lg:grid-cols-2 gap-20 items-center mb-12">
            <div class="text-left animate-fade-in relative z-10">
                <div class="absolute -top-20 -left-20 w-64 h-64 bg-[#a88c5a]/10 blur-[120px] rounded-full pointer-events-none"></div>
                <div id="hero-badge" class="badge-market !mb-6"><%= t.badge %></div>
                <h1 id="h1-text" class="text-4xl md:text-5xl font-black mb-10 leading-tight tracking-tight uppercase whitespace-pre-line">
                    <span class="gradient-text"><%- t.h1 %></span>
                </h1>
                <p id="sub-text" class="text-xl md:text-2xl text-white/40 max-w-xl mb-12 font-medium leading-relaxed">
                    <%= t.sub %>
                </p>
                
                <div class="flex flex-wrap gap-8 items-center">
                    <button id="v2-hero-trigger" class="pill-btn pill-btn-vault px-12 py-5 text-xs uppercase tracking-[0.3em] font-black group">
                        <span class="relative z-10"><%= t.cta %></span>
                        <div class="btn-slide"></div>
                    </button>
                    <div class="flex items-center gap-4 px-6 py-3 rounded-2xl border border-white/5 bg-white/2 backdrop-blur-md">
                        <div class="flex -space-x-2">
                            <div class="w-6 h-6 rounded-full bg-[#a88c5a] border-2 border-black flex items-center justify-center text-[10px] font-bold text-black italic">E</div>
                            <div class="w-6 h-6 rounded-full bg-white border-2 border-black flex items-center justify-center text-[10px] font-bold text-black italic">S</div>
                            <div class="w-6 h-6 rounded-full bg-[#a88c5a] border-2 border-black flex items-center justify-center text-[10px] font-bold text-black italic">P</div>
                        </div>
                        <span class="text-[10px] font-black tracking-widest text-white/60 uppercase">ESPR 2027 Compliance Standard ready</span>
                    </div>
                </div>
            </div>
            
            <div class="relative group animate-float">
                <!-- Made in Germany Trust Badge -->
                <div class="absolute -top-10 -right-10 z-20 apple-glass-dark px-6 py-4 rounded-[2rem] border border-white/20 shadow-2xl flex items-center gap-4 hover:scale-105 transition-transform duration-500 cursor-default backdrop-blur-3xl group-hover:border-[#a88c5a]/50">
                    <img src="/assets/german-seal.png" alt="Made in Germany" class="w-16 h-16 rounded-full shadow-lg">
                    <div class="flex flex-col">
                        <span class="text-[8px] font-black tracking-[0.2em] text-[#a88c5a] uppercase">Trust Standard</span>
                        <span class="text-xs font-bold text-white/90 whitespace-nowrap"><%= t.madeInGermany %></span>
                    </div>
                </div>

                <div class="absolute -inset-10 bg-gradient-to-tr from-[#a88c5a]/20 to-transparent blur-[100px] opacity-40 group-hover:opacity-60 transition-opacity duration-1000"></div>
                <div class="relative apple-glass rounded-[4rem] overflow-hidden border border-white/10 shadow-[0_0_100px_rgba(0,0,0,0.8)]">
                    <img src="/assets/hero-elite.png" alt="High-Value Goods at Harbor" class="w-full aspect-[4/5] object-cover mix-blend-lighten opacity-95 transition-transform duration-1000 group-hover:scale-110">
                    <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent"></div>
                    <div class="absolute bottom-10 left-10 right-10 p-8 apple-glass-dark rounded-[2rem] border-white/10 backdrop-blur-3xl transform translate-y-4 group-hover:translate-y-0 transition-transform duration-700">
                        <div class="flex items-center gap-4 mb-3">
                            <div class="w-2 h-2 rounded-full bg-[#a88c5a] animate-pulse"></div>
                            <div class="text-[10px] font-black tracking-[0.3em] uppercase text-[#a88c5a]">Asset Status: Blocked</div>
                        </div>
                        <div class="text-lg font-bold text-white/90 leading-tight">Securing Batteries, Textiles & Luxury Exports against EU Customs barriers.</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tech Authority Bar: Build 9.0 Minimalist -->
        <div class="flex flex-wrap justify-between items-center gap-10 mb-6 py-5 border-y border-white/5 opacity-50 hover:opacity-100 transition-all duration-1000 bg-gradient-to-x from-transparent via-white/[0.02] to-transparent">
            <div class="flex items-center gap-4 group">
                <div class="w-8 h-8 rounded-lg bg-white/5 flex items-center justify-center border border-white/10 group-hover:border-[#a88c5a]/50 transition-colors">
                    <svg class="text-white/40 group-hover:text-[#a88c5a]" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="8" rx="2" ry="2"></rect><rect x="2" y="14" width="20" height="8" rx="2" ry="2"></rect><line x1="6" y1="6" x2="6" y2="6"></line><line x1="6" y1="18" x2="6" y2="18"></line></svg>
                </div>
                <span class="text-[11px] font-black tracking-[0.3em] uppercase">Base L2 Infrastructure</span>
            </div>
            <div class="flex items-center gap-4 group">
                <div class="w-8 h-8 rounded-lg bg-white/5 flex items-center justify-center border border-white/10 group-hover:border-[#a88c5a]/50 transition-colors">
                    <svg class="text-white/40 group-hover:text-[#a88c5a]" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
                </div>
                <span class="text-[11px] font-black tracking-[0.3em] uppercase">NXP Secure Identity</span>
            </div>
            <div class="flex items-center gap-4 group">
                <div class="w-8 h-8 rounded-lg bg-white/5 flex items-center justify-center border border-white/10 group-hover:border-[#a88c5a]/50 transition-colors">
                    <svg class="text-white/40 group-hover:text-[#a88c5a]" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline></svg>
                </div>
                <span class="text-[11px] font-black tracking-[0.3em] uppercase">ERC-4337 Full Abstraction</span>
            </div>
        </div>

        <!-- Flying Article Stack: Build 21.0 (The Epic 6-Part Story) -->
        <div id="article-stack" class="article-stack-section mb-32">
            <div class="sticky-reveal-wrapper article-stack-wrapper">
                
                <!-- Slide 1: SaaS platform -->
                <div class="article-row-stack reveal-on-scroll" data-index="0">
                    <div class="article-row max-w-7xl mx-auto px-6 md:px-12">
                        <div class="article-image-container flex-1.2 relative">
                            <div class="article-glow"></div>
                            <img src="/assets/slider-1.png" alt="SaaS Scanning Platform - ESPR Compliance Gateway Duisburg" class="w-full h-auto">
                        </div>
                        <div class="article-text-container flex-1">
                            <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-[#a88c5a]/30 bg-[#a88c5a]/10 text-[#a88c5a] text-[10px] uppercase tracking-widest font-black mb-8">
                                01 / The Foundation
                            </div>
                            <h3 class="text-2xl md:text-4xl font-black mb-8 tracking-tight uppercase leading-tight text-white">
                                <%- t.s1h %>
                            </h3>
                            <p class="text-xl text-white/40 leading-relaxed font-medium">
                                <%= t.s1p %>
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Slide 2: Passive Income -->
                <div class="article-row-stack reveal-on-scroll" data-index="1">
                    <div class="article-row article-row-reverse max-w-7xl mx-auto px-6 md:px-12">
                        <div class="article-image-container flex-1.2 relative">
                            <div class="article-glow"></div>
                            <img src="/assets/slider-2.png" alt="Royalty Revenue Stream - Passive Income through Tokenized Export" class="w-full h-auto">
                        </div>
                        <div class="article-text-container flex-1 text-right md:text-left">
                            <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-[#a88c5a]/30 bg-[#a88c5a]/10 text-[#a88c5a] text-[10px] uppercase tracking-widest font-black mb-8">
                                02 / The Revenue Model
                            </div>
                            <h3 class="text-2xl md:text-4xl font-black mb-8 tracking-tight uppercase leading-tight text-white">
                                <%- t.s2h %>
                            </h3>
                            <p class="text-xl text-white/40 leading-relaxed font-medium">
                                <%= t.s2p %>
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Slide 3: Wallets (AA) -->
                <div class="article-row-stack reveal-on-scroll" data-index="2">
                    <div class="article-row max-w-7xl mx-auto px-6 md:px-12">
                        <div class="article-image-container flex-1.2 relative">
                            <div class="article-glow"></div>
                            <img src="/assets/tech-wall-1.png" alt="Invisible Wallets - Seamless Account Abstraction for B2B Export" class="w-full h-auto">
                        </div>
                        <div class="article-text-container flex-1">
                            <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-[#a88c5a]/30 bg-[#a88c5a]/10 text-[#a88c5a] text-[10px] uppercase tracking-widest font-black mb-8">
                                03 / User Experience
                            </div>
                            <h4 class="text-2xl md:text-4xl font-black mb-8 tracking-tight uppercase leading-tight text-white">
                                <%= t.p1h %>
                            </h4>
                            <p class="text-xl text-white/40 leading-relaxed font-medium">
                                <%= t.p1d %>
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Slide 4: Real World Assets -->
                <div class="article-row-stack reveal-on-scroll" data-index="3">
                    <div class="article-row article-row-reverse max-w-7xl mx-auto px-6 md:px-12">
                        <div class="article-image-container flex-1.2 relative">
                            <div class="article-glow"></div>
                            <img src="/assets/tech-wall-2.png" alt="Tokenized Exports - Digital Twins on Blockchain for Battery Passports" class="w-full h-auto">
                        </div>
                        <div class="article-text-container flex-1 text-right md:text-left">
                            <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-[#a88c5a]/30 bg-[#a88c5a]/10 text-[#a88c5a] text-[10px] uppercase tracking-widest font-black mb-8">
                                04 / Digital Twins
                            </div>
                            <h4 class="text-2xl md:text-4xl font-black mb-8 tracking-tight uppercase leading-tight text-white">
                                <%= t.p2h %>
                            </h4>
                            <p class="text-xl text-white/40 leading-relaxed font-medium">
                                <%= t.p2d %>
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Slide 5: The Ledger -->
                <div class="article-row-stack reveal-on-scroll" data-index="4">
                    <div class="article-row max-w-7xl mx-auto px-6 md:px-12">
                        <div class="article-image-container flex-1.2 relative">
                            <div class="article-glow"></div>
                            <img src="/assets/tech-wall-3.png" alt="High Performance Ledger - Base L2 Secure Blockchain Gateway" class="w-full h-auto">
                        </div>
                        <div class="article-text-container flex-1">
                            <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-[#a88c5a]/30 bg-[#a88c5a]/10 text-[#a88c5a] text-[10px] uppercase tracking-widest font-black mb-8">
                                05 / The Digital Backbone
                            </div>
                            <h4 class="text-2xl md:text-4xl font-black mb-8 tracking-tight uppercase leading-tight text-white">
                                <%= t.p3h %>
                            </h4>
                            <p class="text-xl text-white/40 leading-relaxed font-medium">
                                <%= t.p3d %>
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Slide 6: Physical Security -->
                <div class="article-row-stack reveal-on-scroll" data-index="5">
                    <div class="article-row article-row-reverse max-w-7xl mx-auto px-6 md:px-12">
                        <div class="article-image-container flex-1.2 relative">
                            <div class="article-glow"></div>
                            <img src="/assets/tech-wall-4.png" alt="NXP Secure Element - Unforgeable Identity for German Export Products" class="w-full h-auto">
                        </div>
                        <div class="article-text-container flex-1 text-right md:text-left">
                            <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-[#a88c5a]/30 bg-[#a88c5a]/10 text-[#a88c5a] text-[10px] uppercase tracking-widest font-black mb-8">
                                06 / Physical Trust
                            </div>
                            <h4 class="text-2xl md:text-4xl font-black mb-8 tracking-tight uppercase leading-tight text-white">
                                <%= t.p4h %>
                            </h4>
                            <p class="text-xl text-white/40 leading-relaxed font-medium">
                                <%= t.p4d %>
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Progress UI -->
                <div class="reveal-progress-container !left-[8%]">
                    <div id="stack-progress-fill" class="reveal-progress-fill"></div>
                </div>
            </div>
        </div>

        <!-- Section Transition Padding -->
        <div class="h-24"></div>

        <div class="mb-48 text-center max-w-4xl mx-auto px-6">
            <p id="quote-text" class="text-2xl md:text-3xl font-medium leading-relaxed mb-6 text-white/80 italic">
                <%= t.quote %>
            </p>
            <p id="quote-sub" class="section-header"><%= t.quotesub %></p>
        </div>

        <!-- FAQ Section: Build 3.0 Apple Glass Accordion -->
        <section id="faq" class="max-w-4xl mx-auto px-6 mb-48">
            <h2 class="text-3xl md:text-4xl font-black mb-16 tracking-tight uppercase text-center">
                <%= t.faqTitle %>
            </h2>
            <div class="space-y-4">
                <% t.faqs.forEach((faq, index) => { %>
                <div class="faq-item apple-glass rounded-[2rem] border border-white/5 overflow-hidden transition-all duration-500 hover:border-[#a88c5a]/30">
                    <button class="faq-trigger w-full text-left px-8 py-7 flex justify-between items-center group">
                        <span class="text-lg md:text-xl font-bold text-white/90 group-hover:text-white transition-colors uppercase tracking-tight">
                            <%= faq.q %>
                        </span>
                        <div class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center border border-white/10 group-hover:border-[#a88c5a]/50 transition-all transform group-hover:rotate-180">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-[#a88c5a]"><path d="M6 9l6 6 6-6"></path></svg>
                        </div>
                    </button>
                    <div class="faq-content max-h-0 overflow-hidden transition-all duration-700 ease-in-out bg-white/[0.02]">
                        <div class="px-8 pb-8 pt-2 text-white/50 text-lg leading-relaxed font-medium">
                            <%= faq.a %>
                        </div>
                    </div>
                </div>
                <% }); %>
            </div>
        </section>

        <!-- Strategy Button at Bottom -->
        <div class="flex justify-center mt-48 mb-24">
            <button id="v2-bottom-trigger" class="pill-btn pill-btn-vault px-20 py-6 text-lg uppercase tracking-widest font-black group">
                <span class="relative z-10"><%= t.contact %></span>
                <div class="btn-slide"></div>
            </button>
        </div>
    </main>

    <%- include('partials/footer', { t }) %>
    <%- include('partials/cookie_consent', { t }) %>
    <script src="/js/cookie-consent.js?v=20.0" defer></script>
</body>
</html>
