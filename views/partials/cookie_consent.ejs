<!-- The Gatekeeper: Cloudflare-Style Cookie Consent -->
<div id="cookie-barrier" class="fixed inset-0 z-[10000] bg-black/60 backdrop-blur-2xl opacity-0 pointer-events-none transition-opacity duration-1000 flex items-end">
    
    <!-- Inner Container for Alignment -->
    <div class="w-full max-w-7xl mx-auto px-6 pb-12">
        <div class="apple-glass-dark border border-white/10 rounded-[2.5rem] p-8 md:p-12 shadow-[0_50px_100px_rgba(0,0,0,0.8)] relative overflow-hidden group">
            
            <!-- Animated Scanline Effect -->
            <div class="absolute inset-0 bg-gradient-to-t from-[#a88c5a]/5 to-transparent opacity-30 pointer-events-none"></div>
            <div class="absolute top-0 left-0 w-full h-[1px] bg-[#a88c5a]/20 animate-scanline"></div>

            <div class="relative z-10">
                <!-- Header with Status -->
                <div class="flex flex-col md:flex-row md:items-center justify-between gap-8 mb-10">
                    <div>
                        <div class="flex items-center gap-3 mb-4">
                            <div class="w-2 h-2 rounded-full bg-[#a88c5a] animate-pulse"></div>
                            <span class="text-[10px] font-black tracking-widest text-[#a88c5a] uppercase"><%= t.cookie.title %></span>
                        </div>
                        <h2 class="text-2xl md:text-3xl font-black text-white tracking-tighter uppercase leading-none">
                            Identity & Compliance Verification
                        </h2>
                    </div>
                    
                    <!-- Cosmetic System Status -->
                    <div class="flex items-center gap-6 py-3 px-6 bg-white/5 border border-white/10 rounded-2xl whitespace-nowrap">
                        <div class="flex flex-col">
                            <span class="text-[8px] font-black text-white/30 uppercase tracking-[0.2em] mb-1">Infrastructure Status</span>
                            <span class="text-[10px] font-bold text-[#a88c5a] uppercase tracking-widest">Active & Protected</span>
                        </div>
                    </div>
                </div>

                <!-- Message -->
                <p class="text-white/50 text-sm md:text-base leading-relaxed mb-12 max-w-3xl">
                    <%= t.cookie.msg %>
                </p>

                <!-- Actions -->
                <div class="flex flex-wrap gap-4 items-center">
                    <button id="cookie-accept" class="pill-btn pill-btn-primary px-10 py-4 text-[10px] font-black uppercase tracking-[0.2em]">
                        <%= t.cookie.accept %>
                    </button>
                    <button id="cookie-reject" class="px-8 py-4 rounded-full border border-white/10 hover:bg-white/5 text-[10px] font-black text-white/40 hover:text-white uppercase tracking-[0.2em] transition-all">
                        <%= t.cookie.reject %>
                    </button>
                    <button id="cookie-settings" class="px-6 py-4 text-[10px] font-black text-white/20 hover:text-[#a88c5a] uppercase tracking-[0.2em] transition-colors ml-auto md:ml-0">
                        <%= t.cookie.settings %>
                    </button>
                </div>
            </div>
            
            <!-- Cosmetic Check Progress -->
            <div class="absolute bottom-0 left-0 w-full h-1 bg-white/5">
                <div id="cookie-scan-progress" class="h-full bg-[#a88c5a] w-0 transition-all duration-[3000ms] ease-out"></div>
            </div>
        </div>
    </div>
</div>
