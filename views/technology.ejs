<!DOCTYPE html>
<html lang="<%= t.lang %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/png" href="/assets/coin-icon.png">
    <title><%- t.tech?.title || 'Technologie & Vertrieb' %> | V-LEDGER</title>
    <meta name="description" content="<%- t.tech?.subtitle || '' %>">
    <meta name="robots" content="index, follow">
    
    <!-- SEO: Canonical and Hreflang Clusters -->
    <link rel="canonical" href="https://V-Ledger.com/<%= t.lang %>/technology">
    <!-- Hreflang Clusters (Global AI Indexing) -->
    <link rel="alternate" hreflang="de-de" href="https://V-Ledger.com/de-de/technology">
    <link rel="alternate" hreflang="en-us" href="https://V-Ledger.com/en-us/technology">
    <link rel="alternate" hreflang="es-es" href="https://V-Ledger.com/es-es/technology">
    <link rel="alternate" hreflang="vi-vn" href="https://V-Ledger.com/vi-vn/technology">
    <link rel="alternate" hreflang="th-th" href="https://V-Ledger.com/th-th/technology">
    <link rel="alternate" hreflang="ja-jp" href="https://V-Ledger.com/ja-jp/technology">
    <link rel="alternate" hreflang="ko-kr" href="https://V-Ledger.com/ko-kr/technology">
    <link rel="alternate" hreflang="hi-in" href="https://V-Ledger.com/hi-in/technology">
    <link rel="alternate" hreflang="bn-bd" href="https://V-Ledger.com/bn-bd/technology">
    <link rel="alternate" hreflang="zh-cn" href="https://V-Ledger.com/zh-cn/technology">
    <link rel="alternate" hreflang="zh-tw" href="https://V-Ledger.com/zh-tw/technology">
    <link rel="alternate" hreflang="x-default" href="https://V-Ledger.com/en-us/technology">

    <!-- Social Preview -->
    <meta property="og:title" content="<%- t.tech?.title || 'Technologie' %> | V-LEDGER">
    <meta property="og:description" content="<%- t.tech?.subtitle || '' %>">
    <meta property="og:image" content="https://V-Ledger.com/assets/hero-elite.png">
    <meta property="og:type" content="website">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:image" content="https://V-Ledger.com/assets/hero-elite.png">

    <!-- Schema -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "V-LEDGER",
      "address": {
            "@type": "PostalAddress",
            "streetAddress": "Albertstr. 7",
            "postalCode": "47059",
            "addressLocality": "Duisburg",
            "addressRegion": "NRW",
            "addressCountry": "DE"
          },
      "url": "https://V-Ledger.com/technology"
    }
    </script>
    
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800;900&display=swap" rel="stylesheet">
    <!-- Flag Icons for Header -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/lipis/flag-icons@7.0.0/css/flag-icons.min.css"/>
    <link rel="stylesheet" href="/css/style.css?v=15.0">
</head>
<body class="selection:bg-[#d4af37] selection:text-black overflow-x-hidden">
    <div class="mesh-bg opacity-30"></div>

    <%- include('partials/header', { t }) %>

    <main class="max-w-7xl mx-auto px-6 py-24 md:py-32 min-h-screen relative z-10">
        
        <!-- Hero Section -->
        <div class="text-center mb-20 relative">
            <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-64 h-64 bg-[#d4af37]/20 blur-[100px] rounded-full pointer-events-none"></div>
            
            <h1 class="text-5xl md:text-7xl font-black mb-6 tracking-tighter uppercase leading-[0.9]">
                <%- t.tech?.title || 'Technologie & Vertrieb' %>
            </h1>
            <p class="text-xl md:text-2xl font-light text-white/70 max-w-2xl mx-auto">
                <%- t.tech?.subtitle || 'Die Vorteile der Blockchain für Ihren globalen Handel.' %>
            </p>
        </div>

        <!-- Combined Content Area -->
        <div class="opacity-0 translate-y-10 animate-fade-in-up" style="animation: fadeInUp 1s ease 0.2s forwards;">
            <div class="prose prose-invert prose-xl max-w-none 
                        prose-h3:text-3xl md:prose-h3:text-5xl prose-h3:font-black prose-h3:text-white prose-h3:tracking-tighter prose-h3:mb-12 prose-h3:text-center
                        prose-p:text-white/40 prose-p:leading-relaxed prose-p:font-medium prose-p:text-lg prose-p:text-center prose-p:max-w-3xl prose-p:mx-auto
                        prose-strong:text-[#a88c5a] prose-strong:font-bold">
                <%- t.tech?.content || '<h3>Inhalt folgt...</h3><p>Bitte Übersetzungen hinzufügen.</p>' %>
            </div>
        </div>

    </main>

    <%- include('partials/footer', { t }) %>

    <!-- Custom Fade In Animation -->
    <style>
        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(40px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        .animate-fade-in-up {
            animation-play-state: paused;
        }
        .animate-fade-in-up.is-visible {
            animation-play-state: running;
        }
    </style>
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const elements = document.querySelectorAll('.animate-fade-in-up');
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('is-visible');
                    }
                });
            }, { threshold: 0.1 });
            
            elements.forEach(el => observer.observe(el));
        });
    </script>
    <script src="/js/main.js?v=15.7"></script>    <%- include('partials/cookie_consent', { t }) %>
    <script src="/js/cookie-consent.js?v=20.0" defer></script>
</body>
</html>
