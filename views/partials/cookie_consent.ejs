<!-- The Gatekeeper: Cloudflare-Style Cookie Consent -->
<div id="cookie-barrier" class="fixed inset-0 z-[10000] bg-black/20 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-700 flex items-end justify-center pb-0 md:pb-6">
    
    <!-- Inner Container for Alignment -->
    <div class="w-full max-w-7xl mx-auto px-0 md:px-6">
        <div class="apple-glass-dark border-t md:border border-white/10 rounded-t-[2rem] md:rounded-3xl p-6 md:p-8 shadow-[0_-20px_50px_rgba(0,0,0,0.5)] relative overflow-hidden group flex flex-col lg:flex-row lg:items-center justify-between gap-6">
            
            <!-- Animated Scanline Effect -->
            <div class="absolute inset-0 bg-gradient-to-t from-[#a88c5a]/5 to-transparent opacity-30 pointer-events-none"></div>
            <div class="absolute top-0 left-0 w-full h-[1px] bg-[#a88c5a]/20 animate-scanline"></div>

            <div class="relative z-10 flex-1">
                <div class="flex items-center gap-3 mb-2">
                    <div class="w-2 h-2 rounded-full bg-[#a88c5a] animate-pulse"></div>
                    <span class="text-[10px] font-black tracking-widest text-[#a88c5a] uppercase"><%= t.cookie.title %></span>
                </div>
                <p class="text-white/60 text-sm leading-relaxed max-w-4xl">
                    <%= t.cookie.msg %>
                </p>
            </div>
            
            <!-- Actions -->
            <div class="relative z-10 flex flex-wrap gap-3 items-center shrink-0">
                <button id="cookie-accept" class="pill-btn pill-btn-primary px-8 py-3 text-[10px] font-black uppercase tracking-[0.2em] whitespace-nowrap">
                    <%= t.cookie.accept %>
                </button>
                <button id="cookie-reject" class="px-6 py-3 rounded-full border border-white/10 hover:bg-white/5 text-[10px] font-black text-white/40 hover:text-white uppercase tracking-[0.2em] transition-all whitespace-nowrap">
                    <%= t.cookie.reject %>
                </button>
                <button id="cookie-settings" class="px-4 py-3 text-[10px] font-black text-white/20 hover:text-[#a88c5a] uppercase tracking-[0.2em] transition-colors whitespace-nowrap">
                    <%= t.cookie.settings %>
                </button>
            </div>
            
            <!-- Cosmetic Check Progress -->
            <div class="absolute bottom-0 left-0 w-full h-1 bg-white/5">
                <div id="cookie-scan-progress" class="h-full bg-[#a88c5a] w-0 transition-all duration-[3000ms] ease-out"></div>
            </div>
        </div>
    </div>
</div>
